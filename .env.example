# ============================================================
# Choice Healthcare Tracker — env vars
# Copy to .env.local for local dev. Set these on Vercel for prod.
# ============================================================

# --- Supabase ---------------------------------------------------------------
# Hosted demo (current team default) — get anon + service_role from Addison / 1Password:
# NEXT_PUBLIC_SUPABASE_URL=https://ftxxexwzrhyrqjguagbi.supabase.co
#
# Local Supabase CLI (`supabase start`):
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-anon-key-from-supabase-status

# Service role key (server-only; NEVER expose to the browser).
# Only needed for admin scripts and seed-script utilities.
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key-from-supabase-status

# --- Auth providers (config-driven, see src/lib/auth-providers.ts) ----------
NEXT_PUBLIC_AUTH_AZURE_ENABLED=true
NEXT_PUBLIC_AUTH_GOOGLE_ENABLED=false
NEXT_PUBLIC_AUTH_EMAIL_ENABLED=true

# Microsoft (Azure AD / Entra) OAuth credentials.
# Required only when you actually want the Microsoft button to work.
# Register an app in Entra (https://entra.microsoft.com) and grant
# delegated permissions for openid, profile, email, User.Read.
SUPABASE_AUTH_EXTERNAL_AZURE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_AZURE_SECRET=
