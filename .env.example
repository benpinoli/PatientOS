# ============================================================
# Choice Healthcare Tracker — env vars
# Copy to .env.local for local dev.
# ============================================================

# --- Supabase (AWS self-hosted — recommended) ----------------------------
# Self-hosted open-source stack on EC2 (see infra/aws/DEPLOYMENT.md).
# Local dev: talk to EC2 directly (HTTP is fine on localhost).
NEXT_PUBLIC_SUPABASE_URL=http://32.185.154.166:8000
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-anon-key-from-ec2-env

# Amplify production: proxy HTTPS → EC2 HTTP (avoids mixed-content errors).
# SUPABASE_INTERNAL_URL=http://32.185.154.166:8000
# NEXT_PUBLIC_SUPABASE_URL=https://main.<app-id>.amplifyapp.com/supabase

# --- Retired: managed Supabase cloud (do not use for new deploys) --------
# NEXT_PUBLIC_SUPABASE_URL=https://ftxxexwzrhyrqjguagbi.supabase.co

# Local Supabase CLI (`supabase start`):
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321

# Service role key (server-only; NEVER expose to the browser).
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# --- Auth providers (config-driven, see src/lib/auth-providers.ts) ----------
NEXT_PUBLIC_AUTH_AZURE_ENABLED=false
NEXT_PUBLIC_AUTH_GOOGLE_ENABLED=false
NEXT_PUBLIC_AUTH_EMAIL_ENABLED=true

# Microsoft (Azure AD / Entra) OAuth credentials.
SUPABASE_AUTH_EXTERNAL_AZURE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_AZURE_SECRET=

# --- Paperwork AI (Gemini) -------------------------------------------------
# Server-only Gemini API key used by /api/paperwork/* routes. NEVER expose to
# the browser (do not prefix with NEXT_PUBLIC). Until a Google Cloud / Vertex
# AI BAA is in place, only send SYNTHETIC patient data to this API.
GEMINI_API_KEY=you_API_KEY_HERE
# Optional model override (default gemini-3.1-flash-lite). The AI calls run in
# the EC2 paperwork-worker container (see infra/aws/paperwork-worker/), so set
# GEMINI_MODEL there too if you change it.
# GEMINI_MODEL=gemini-3.1-flash-lite
