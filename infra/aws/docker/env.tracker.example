# Copy to the Supabase docker folder as additions after copying .env.example → .env
# Full variable list lives in upstream supabase/docker/.env.example

# Public URL of this stack (Elastic IP, domain, or tunnel). Kong listens on :8000.
SUPABASE_PUBLIC_URL=http://YOUR_ELASTIC_IP:8000
API_EXTERNAL_URL=http://YOUR_ELASTIC_IP:8000
SITE_URL=http://localhost:3000

# After Amplify deploy, set SITE_URL to your Amplify URL for OAuth redirects:
# SITE_URL=https://main.d1234abcd.amplifyapp.com

# Tracker app — enable email for pilot; Azure when Entra app is registered
ADDITIONAL_REDIRECT_URLS=

# Microsoft OAuth (GoTrue external provider) — optional until Entra is wired
# GOTRUE_EXTERNAL_AZURE_ENABLED=true
# GOTRUE_EXTERNAL_AZURE_CLIENT_ID=
# GOTRUE_EXTERNAL_AZURE_SECRET=
# GOTRUE_EXTERNAL_AZURE_REDIRECT_URI=http://YOUR_ELASTIC_IP:8000/auth/v1/callback
