{
  "permissions": {
    "ask": [
      "Bash(git push:*)",
      "Bash(ssh:*)",
      "Bash(scp:*)",
      "Bash(./infra/aws/scripts/:*)",
      "Bash(bash infra/aws/scripts/:*)",
      "Bash(sh infra/aws/scripts/:*)"
    ],
    "allow": [
      "Bash",
      "Edit",
      "Write",
      "Read",
      "Glob",
      "Grep"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/check-gstack.sh\""
          }
        ]
      }
    ]
  }
}
